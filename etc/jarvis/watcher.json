{
  "version": 1,
  "staleness_multiplier": 2.5,
  "system_crons": [
    {
      "id": "claude-token-refresh",
      "description": "Claude/Anthropic token refresh",
      "cadence_minutes": 240,
      "output_path": "/tmp/claude-token-heartbeat.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/claude-token-refresh-heartbeat.json"
    },
    {
      "id": "cli-usage-tracker",
      "description": "CLI usage tracker",
      "cadence_minutes": 30,
      "output_path": "/tmp/cli-usage.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/cli-usage-tracker-heartbeat.json",
      "validation": {
        "type": "json",
        "required_keys": [
          "checked_at",
          "providers"
        ],
        "timestamp_field": "checked_at",
        "timestamp_max_age_minutes": 35,
        "non_empty_fields": [
          "providers"
        ]
      }
    },
    {
      "id": "bootstrap-audit",
      "description": "Weekly bootstrap audit",
      "cadence_minutes": 10080,
      "output_path": "/home/openclaw/.openclaw/workspace/bootstrap-audit.log",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/bootstrap-audit-heartbeat.json"
    },
    {
      "id": "cost-sentinel",
      "description": "Daily cost sentinel",
      "cadence_minutes": 1440,
      "output_path": "/home/openclaw/.openclaw/workspace/cost-sentinel-status.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/cost-sentinel-heartbeat.json",
      "validation": {
        "type": "json",
        "required_keys": [
          "generated_at",
          "overall_status",
          "checks"
        ],
        "timestamp_field": "generated_at",
        "timestamp_max_age_minutes": 1500
      }
    },
    {
      "id": "gemini-rate-tracker",
      "description": "Gemini API rate limit tracker",
      "cadence_minutes": 5,
      "output_path": "/home/openclaw/.openclaw/workspace/gemini-rate-status.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/gemini-rate-tracker-heartbeat.json",
      "validation": {
        "type": "json",
        "required_keys": [
          "timestamp",
          "status"
        ],
        "timestamp_field": "timestamp",
        "timestamp_max_age_minutes": 8
      }
    },
    {
      "id": "system-health",
      "description": "System health check",
      "cadence_minutes": 5,
      "output_path": "/home/openclaw/.openclaw/workspace/health-status.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/system-health-heartbeat.json",
      "validation": {
        "type": "json",
        "required_keys": [],
        "non_empty_fields": []
      }
    },
    {
      "id": "memory-ingest",
      "description": "Daily memory fact extraction",
      "cadence_minutes": 1440,
      "output_path": "/home/openclaw/.openclaw/memory/ingest.log",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/memory-ingest-heartbeat.json",
      "validation": {
        "type": "log_no_errors",
        "file": "/home/openclaw/.openclaw/memory/ingest.log"
      }
    },
    {
      "id": "memory-prune",
      "description": "Hourly memory decay pruning",
      "cadence_minutes": 60,
      "output_path": "/home/openclaw/.openclaw/memory/prune.log",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/memory-prune-heartbeat.json",
      "validation": {
        "type": "log_no_errors",
        "file": "/home/openclaw/.openclaw/memory/prune.log"
      }
    },
    {
      "id": "watchdog",
      "description": "Consolidated restart watchdog",
      "cadence_minutes": 2,
      "output_path": "/tmp/openclaw-api-liveness.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/watchdog-heartbeat.json",
      "validation": {
        "type": "json",
        "required_keys": [
          "timestamp",
          "api_alive",
          "memory_status"
        ],
        "timestamp_field": "timestamp",
        "timestamp_max_age_minutes": 5
      }
    },
    {
      "id": "session-ops",
      "description": "Unified session operations",
      "cadence_minutes": 5,
      "output_path": "/tmp/session-ops-heartbeat.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/session-ops-heartbeat.json"
    },
    {
      "id": "security-health",
      "description": "Security health audit (38 checks)",
      "cadence_minutes": 15,
      "output_path": "/tmp/security-health-results.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/security-health-heartbeat.json",
      "validation": {
        "type": "json",
        "required_keys": [
          "generated_at",
          "overall_status",
          "checks"
        ],
        "timestamp_field": "generated_at",
        "timestamp_max_age_minutes": 20
      }
    },
    {
      "id": "security-hook-alert",
      "description": "Security hook alert monitor",
      "cadence_minutes": 5,
      "output_path": "/tmp/security-hook-heartbeat.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/security-hook-alert-heartbeat.json"
    },
    {
      "id": "version-check",
      "description": "OpenClaw version check",
      "cadence_minutes": 60,
      "output_path": "/tmp/openclaw-version-check.json",
      "check_method": "heartbeat_v2",
      "heartbeat_path": "/tmp/version-check-heartbeat.json",
      "validation": {
        "type": "json",
        "required_keys": [
          "checked_at",
          "status"
        ],
        "timestamp_field": "checked_at",
        "timestamp_max_age_minutes": 65
      }
    }
  ],
  "gateway_crons": {
    "jobs_file": "/home/openclaw/.openclaw/cron/jobs.json",
    "alert_on_consecutive_errors": 1,
    "alert_on_disabled_with_errors": true
  }
}
